datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Models generated by `kiln generate model` are appended below this line.
// Do not remove the marker comment — the generator looks for it.
model Post {
  id        Int      @id @default(autoincrement())
  title String
  body String
  published Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("posts")
}

// KILN:MODELS
